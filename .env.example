# Local environment variables for the relocation scrapers.
# Copy this file to `.env` and fill in real values.
# DO NOT commit the real .env file to git (it's in .gitignore).

# The ID of your Google Sheet. Find it in the URL:
# docs.google.com/spreadsheets/d/THIS_PART/edit
SPREADSHEET_ID=

# Path to the service-account JSON file you downloaded from Google Cloud.
# (Or, alternatively, paste the entire JSON content into
#  GOOGLE_SHEETS_CREDENTIALS_JSON — useful for CI environments.)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Uncomment and paste the full JSON if you'd rather not use a file:
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","..."}
